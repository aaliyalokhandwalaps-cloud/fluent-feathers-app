# Fluent Feathers LMS - Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production
SELF_PING_URL=
SELF_PING_USE_PUBLIC_URL=false

# Database
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Admin Password (for admin login)
ADMIN_PASSWORD=your_secure_password_here

# Admin Secret (for token signing)
ADMIN_SECRET=your_secret_key_here

# Class Link
CLASS_LINK=https://us06web.zoom.us/j/7288533155?pwd=Nng5N2l0aU12L0FQK245c0VVVHJBUT09

# Zoom Webhook + OAuth (required for auto recording attach)
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_webhook_secret_here
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here

# Brevo Email API
BREVO_API_KEY=your_brevo_api_key_here

# OpenAI (optional, for social media reel voiceover generation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Cloudinary (for file uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Firebase Web Push
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here
FIREBASE_VAPID_KEY=your_firebase_web_push_vapid_key_here

# Firebase Admin Push
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id"}
# Or use a file path instead of FIREBASE_SERVICE_ACCOUNT
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
# Optional legacy fallback
# FIREBASE_SERVER_KEY=your_legacy_fcm_server_key_here

# Logo URL (for emails)
LOGO_URL=https://your-domain.com/logo.png
